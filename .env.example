# ══════════════════════════════════════════════════════════════════════════
# gym-saas-platform — root environment template
# Copy to .env for local development. NEVER commit real values.
# App-specific templates live in apps/<app>/.env.example.
# ══════════════════════════════════════════════════════════════════════════

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Local domains (subdomain-as-tenant, mirrors production) ────────────────
# Add to hosts file / dnsmasq: fitcloud.local, admin.fitcloud.local,
# api.fitcloud.local, *.fitcloud.local → 127.0.0.1
PLATFORM_DOMAIN=fitcloud.local
NEXT_PUBLIC_API_URL=http://api.fitcloud.local/api/v1

# ── Ports ──────────────────────────────────────────────────────────────────
PORT_LANDING=3000
PORT_TENANT=3001
PORT_ADMIN=3002
PORT_API=4000

# ── PostgreSQL (docker-compose service: postgres) ──────────────────────────
# Host port 5433 — avoids clashing with a native PostgreSQL install some
# machines already have running on the default 5432.
DATABASE_URL=postgresql://gym:gym@localhost:5433/gym_saas?schema=public

# ── Redis (docker-compose service: redis) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (placeholders — real keys come from AWS Secrets Manager) ───────────
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_PRIVATE_KEY=__generate_rs256_keypair_for_local__
JWT_PUBLIC_KEY=__generate_rs256_keypair_for_local__

# ── Mail (docker-compose service: mailpit — UI at http://localhost:8025) ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@fitcloud.local

# ── Third-party (test credentials only) ────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
FCM_SERVICE_ACCOUNT_JSON=
PAYMENT_GATEWAY_SECRET_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
AWS_REGION=ap-south-1
S3_BUCKET=gym-saas-dev
