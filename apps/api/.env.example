# @gym-saas/api — copy to .env for local development
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database & cache (docker-compose services)
# Host port 5433 (not 5432) — avoids clashing with a native PostgreSQL
# install some machines already have running on the default port.
DATABASE_URL=postgresql://gym:gym@localhost:5433/gym_saas?schema=public
REDIS_URL=redis://localhost:6379

# Auth — RS256 keypair, base64-encoded PEM (avoids .env newline escaping issues).
# Generate locally with: node scripts/generate-jwt-keys.js
# Real keys live in AWS Secrets Manager/KMS in staging & production.
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=fitcloud
JWT_AUDIENCE=fitcloud-tenant-app

# Platform domains & subdomain resolution
PLATFORM_DOMAIN=fitcloud.local
CORS_ORIGINS=http://fitcloud.local,http://admin.fitcloud.local,http://localhost:3001,http://localhost:3002

# Mail (mailpit in dev — see docker-compose.yml)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM_NAME=FitCloud
MAIL_FROM_ADDRESS=no-reply@fitcloud.local

# Providers (notification-ready placeholders — not required for auth to function)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Password / lockout policy
BCRYPT_SALT_ROUNDS=10
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=24

# Logging
LOG_LEVEL=debug
