# @gym-saas/api — copy to .env for local development
NODE_ENV=development
PORT=4000

# Database & cache (docker-compose services)
DATABASE_URL=postgresql://gym:gym@localhost:5432/gym_saas?schema=public
REDIS_URL=redis://localhost:6379

# Auth (RS256 keypair — generate locally, real keys live in Secrets Manager)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Platform domains
PLATFORM_DOMAIN=fitcloud.local
CORS_ORIGINS=http://fitcloud.local,http://admin.fitcloud.local

# Mail (mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@fitcloud.local

# Providers (test credentials only)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
FCM_SERVICE_ACCOUNT_JSON=
PAYMENT_GATEWAY_SECRET_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
S3_BUCKET=gym-saas-dev
AWS_REGION=ap-south-1

# Logging
LOG_LEVEL=debug
