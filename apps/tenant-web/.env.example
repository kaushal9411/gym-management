# @gym-saas/tenant-web — copy to .env for local development
NEXT_PUBLIC_PLATFORM_DOMAIN=fitcloud.local

# Points at the running @gym-saas/api backend. In production this goes
# through Nginx/Cloudflare at https://api.fitcloud.com/api/v1; for local
# dev, point it directly at the api dev server's port.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
